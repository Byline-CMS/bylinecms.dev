# Copy this file to .env and change the values accordingly,
# including user and password.
# POSTGRES_DATABASE must end in `_dev` or `_test` — db_init.sh
# refuses to operate on any other name (see check_db_suffix in
# common.sh). For the dedicated test database, copy .env.test.example
# to .env.test instead and run `pnpm db:init:test`.
# Note: we set both a connection string and individual variables
# for the same reason — database/common.sh looks for the individual
# variables.
POSTGRES_CONNECTION_STRING=postgres://byline:byline@127.0.0.1:5432/byline_dev
POSTGRES_HOSTNAME=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DATABASE=byline_dev
POSTGRES_USER=byline
POSTGRES_PASSWORD=byline
