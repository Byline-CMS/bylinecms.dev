{
  "name": "@byline/richtext-lexical",
  "private": false,
  "type": "module",
  "license": "MPL-2.0",
  "version": "0.9.2",
  "engines": {
    "node": ">=20.9.0"
  },
  "description": "Byline CMS Lexical richtext editor adapter",
  "keywords": [
    "cms",
    "headless cms",
    "content management",
    "richtext",
    "lexical",
    "editor"
  ],
  "homepage": "https://github.com/Byline-CMS/bylinecms.dev",
  "bugs": {
    "url": "https://github.com/Byline-CMS/bylinecms.dev/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Byline-CMS/bylinecms.dev.git",
    "directory": "packages/richtext-lexical"
  },
  "scripts": {
    "dev": "run-p dev:*",
    "dev:code": "rslib build --watch",
    "build": "run-s build:*",
    "build:clean": "rimraf dist build",
    "build:code": "rslib build",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf node_modules dist build types .turbo",
    "lint": "biome check --write --unsafe --diagnostic-level=error",
    "skip:test": "vitest"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "main": "./dist/index.js",
  "files": [
    "dist/",
    "src/"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "main": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "dependencies": {
    "@byline/client": "workspace:*",
    "@byline/core": "workspace:*",
    "@byline/ui": "workspace:*",
    "@infonomic/uikit": "^6.7.0",
    "@lexical/clipboard": "0.44.0",
    "@lexical/code": "0.44.0",
    "@lexical/hashtag": "0.44.0",
    "@lexical/headless": "0.44.0",
    "@lexical/html": "0.44.0",
    "@lexical/link": "0.44.0",
    "@lexical/list": "0.44.0",
    "@lexical/mark": "0.44.0",
    "@lexical/markdown": "0.44.0",
    "@lexical/overflow": "0.44.0",
    "@lexical/react": "0.44.0",
    "@lexical/rich-text": "0.44.0",
    "@lexical/selection": "0.44.0",
    "@lexical/table": "0.44.0",
    "@lexical/utils": "0.44.0",
    "classnames": "^2.5.1",
    "lexical": "0.44.0",
    "lodash-es": "^4.18.1",
    "npm-run-all": "^4.1.5",
    "prism-react-renderer": "^2.4.1",
    "react-error-boundary": "^6.1.1"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@rsbuild/plugin-react": "^2.0.0",
    "@rslib/core": "^0.21.3",
    "@types/lodash": "^4.17.24",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "lightningcss": "^1.32.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "rimraf": "^6.1.3",
    "typescript": "6.0.3",
    "typescript-plugin-css-modules": "^5.2.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public",
    "files": [
      "dist/",
      "src/"
    ]
  }
}
