{
  "name": "@byline/ui",
  "private": false,
  "type": "module",
  "license": "MPL-2.0",
  "version": "0.9.2",
  "description": "Byline CMS UI package",
  "keywords": [
    "cms",
    "headless cms",
    "content management"
  ],
  "homepage": "https://github.com/Byline-CMS/bylinecms.dev",
  "bugs": {
    "url": "https://github.com/Byline-CMS/bylinecms.dev/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Byline-CMS/bylinecms.dev.git",
    "directory": "packages/ui"
  },
  "scripts": {
    "dev": "run-p dev:*",
    "dev:code": "rslib build --watch",
    "build": "run-s build:*",
    "build:clean": "rimraf dist build",
    "build:code": "rslib build",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf node_modules dist build types .turbo",
    "lint": "biome check --write --unsafe --diagnostic-level=error",
    "skip:test": "vitest"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "types": "./dist/react.d.ts",
  "module": "./dist/react.js",
  "main": "./dist/react.js",
  "files": [
    "dist/",
    "src/"
  ],
  "exports": {
    ".": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "main": "./dist/react.js",
      "default": "./dist/react.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "main": "./dist/react.js",
      "default": "./dist/react.js"
    }
  },
  "dependencies": {
    "@byline/client": "workspace:*",
    "@byline/core": "workspace:*",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@infonomic/uikit": "^6.5.0",
    "@lexical/clipboard": "0.43.0",
    "@lexical/code": "0.43.0",
    "@lexical/hashtag": "0.43.0",
    "@lexical/headless": "0.43.0",
    "@lexical/html": "0.43.0",
    "@lexical/link": "0.43.0",
    "@lexical/list": "0.43.0",
    "@lexical/mark": "0.43.0",
    "@lexical/markdown": "0.43.0",
    "@lexical/overflow": "0.43.0",
    "@lexical/react": "0.43.0",
    "@lexical/rich-text": "0.43.0",
    "@lexical/selection": "0.43.0",
    "@lexical/table": "0.43.0",
    "@lexical/utils": "0.43.0",
    "classnames": "^2.5.1",
    "lexical": "0.43.0",
    "lodash-es": "^4.18.1",
    "npm-run-all": "^4.1.5",
    "prism-react-renderer": "^2.4.1",
    "react-error-boundary": "^6.1.1",
    "zod": "^4.3.6",
    "zod-form-data": "^3.0.1"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@rsbuild/plugin-react": "^1.4.6",
    "@rslib/core": "^0.21.0",
    "@types/lodash": "^4.17.24",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "chokidar": "^5.0.0",
    "lightningcss": "^1.32.0",
    "lightningcss-cli": "^1.32.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "rimraf": "^6.1.3",
    "typescript": "6.0.2",
    "typescript-plugin-css-modules": "^5.2.0",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "publishConfig": {
    "access": "public",
    "files": [
      "dist/",
      "src/"
    ]
  }
}
