{
  "name": "@byline/ui",
  "private": false,
  "type": "module",
  "license": "MPL-2.0",
  "version": "1.7.2",
  "engines": {
    "node": ">=20.9.0"
  },
  "description": "Byline CMS UI package",
  "keywords": [
    "cms",
    "headless cms",
    "content management"
  ],
  "homepage": "https://github.com/Byline-CMS/bylinecms.dev",
  "bugs": {
    "url": "https://github.com/Byline-CMS/bylinecms.dev/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Byline-CMS/bylinecms.dev.git",
    "directory": "packages/ui"
  },
  "scripts": {
    "dev": "run-p dev:*",
    "dev:code": "rslib build --watch",
    "build": "run-s build:*",
    "build:clean": "rimraf dist build",
    "build:code": "rslib build",
    "build:css": "lightningcss --bundle ./src/styles/reset.css ./src/styles/styles.css ./src/styles/typography.css --output-dir ./dist/styles",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf node_modules dist build types .turbo",
    "lint": "biome check --write --unsafe --diagnostic-level=error",
    "skip:test": "vitest",
    "sync:uikit": "./scripts/sync-from-uikit.sh"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist/",
    "src/"
  ],
  "exports": {
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "main": "./dist/react.js",
      "default": "./dist/react.js"
    },
    "./reset.css": {
      "import": "./dist/styles/reset.css",
      "default": "./dist/styles/reset.css"
    },
    "./styles.css": {
      "import": "./dist/styles/styles.css",
      "default": "./dist/styles/styles.css"
    },
    "./typography.css": {
      "import": "./dist/styles/typography.css",
      "default": "./dist/styles/typography.css"
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@byline/admin": "workspace:*",
    "@byline/client": "workspace:*",
    "@byline/core": "workspace:*",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-form-start": "^1.29.1",
    "classnames": "^2.5.1",
    "date-fns": "^4.1.0",
    "lodash-es": "^4.18.1",
    "motion": "^12.38.0",
    "npm-run-all": "^4.1.5",
    "react-day-picker": "^9.14.0",
    "react-diff-viewer-continued": "^4.2.2",
    "zod": "^4.4.2",
    "zod-form-data": "^3.0.1"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@rsbuild/plugin-react": "^2.0.0",
    "@rslib/core": "^0.21.3",
    "@types/lodash": "^4.17.24",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "chokidar": "^5.0.0",
    "lightningcss": "^1.32.0",
    "lightningcss-cli": "^1.32.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "rimraf": "^6.1.3",
    "typescript": "6.0.3",
    "typescript-plugin-css-modules": "^5.2.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public",
    "files": [
      "dist/",
      "src/"
    ]
  }
}
