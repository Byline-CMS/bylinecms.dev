{
  "name": "@byline/generated-types",
  "private": false,
  "license": "MPL-2.0",
  "version": "4.6.1",
  "engines": {
    "node": ">=20.9.0"
  },
  "description": "Byline CMS generated collection types — a declaration-merge target populated by each application's @byline/core codegen output",
  "keywords": [
    "cms",
    "headless cms",
    "content management",
    "typescript",
    "codegen"
  ],
  "homepage": "https://github.com/Byline-CMS/bylinecms.dev",
  "bugs": {
    "url": "https://github.com/Byline-CMS/bylinecms.dev/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Byline-CMS/bylinecms.dev.git",
    "directory": "packages/generated-types"
  },
  "type": "module",
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "lint": "biome check --write --unsafe --diagnostic-level=error",
    "typecheck": "tsc --noEmit index.d.ts"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "require": "./index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "index.d.ts",
    "index.js"
  ],
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "typescript": "^7.0.2"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
