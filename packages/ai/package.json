{
  "name": "@byline/ai",
  "private": false,
  "license": "MPL-2.0",
  "version": "4.6.1",
  "engines": {
    "node": ">=20.9.0"
  },
  "type": "module",
  "description": "Byline CMS AI subsystem.",
  "keywords": [
    "ai",
    "cms",
    "headless cms",
    "content management"
  ],
  "homepage": "https://github.com/Byline-CMS/bylinecms.dev",
  "bugs": {
    "url": "https://github.com/Byline-CMS/bylinecms.dev/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Byline-CMS/bylinecms.dev.git",
    "directory": "packages/ai"
  },
  "sideEffects": false,
  "scripts": {
    "dev": "chokidar 'src/**/*' -c 'npm-run-all build'",
    "build": "node scripts/clean.js dist && tsc -p tsconfig.json && tsc-alias && node copy-assets.js",
    "lint": "biome check --write --unsafe --diagnostic-level=error",
    "clean": "node scripts/clean.js node_modules dist build .turbo",
    "typecheck": "tsc --noEmit",
    "test": "LOG_LEVEL=off vitest run --mode=node",
    "test:watch": "LOG_LEVEL=off vitest --mode=node",
    "list:models": "tsx --env-file=.env src/scripts/list-models.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./plugins/lexical": {
      "types": "./dist/plugins/lexical/index.d.ts",
      "import": "./dist/plugins/lexical/index.js"
    },
    "./plugins/text": {
      "types": "./dist/plugins/text/index.d.ts",
      "import": "./dist/plugins/text/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.1",
    "@byline/core": "workspace:*",
    "@byline/richtext-lexical": "workspace:*",
    "@byline/ui": "workspace:*",
    "@google/genai": "^2.12.0",
    "@lexical/html": "^0.48.0",
    "@lexical/react": "^0.48.0",
    "@lexical/utils": "^0.48.0",
    "ajv": "^8.20.0",
    "lexical": "^0.48.0",
    "openai": "^6.48.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@infonomic/uikit": "^6.7.7",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "chokidar": "^5.0.0",
    "chokidar-cli": "^3.0.0",
    "dotenv": "^17.4.2",
    "jsdom": "^29.1.1",
    "npm-run-all": "^4.1.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsc-alias": "^1.9.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
