{
  "name": "@byline/core",
  "private": false,
  "license": "MPL-2.0",
  "version": "3.20.4",
  "engines": {
    "node": ">=20.9.0"
  },
  "description": "Byline CMS core package",
  "keywords": [
    "cms",
    "headless cms",
    "content management"
  ],
  "homepage": "https://github.com/Byline-CMS/bylinecms.dev",
  "bugs": {
    "url": "https://github.com/Byline-CMS/bylinecms.dev/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Byline-CMS/bylinecms.dev.git",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "dist/index.js",
  "index": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "chokidar 'src/**/*' -c 'npm-run-all build'",
    "build": "tsc -p tsconfig.json && tsc-alias",
    "clean": "node scripts/clean.js node_modules dist build .turbo",
    "lint": "biome check --write --unsafe --diagnostic-level=error",
    "skip": "tsx ./scripts/task-watch.js",
    "test": "vitest run --mode=node",
    "test:watch": "vitest --mode=node",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./codegen": {
      "types": "./dist/codegen/index.d.ts",
      "import": "./dist/codegen/index.js",
      "require": "./dist/codegen/index.js"
    },
    "./zod-schemas": {
      "types": "./dist/schemas/zod/index.d.ts",
      "import": "./dist/schemas/zod/index.js",
      "require": "./dist/schemas/zod/index.js"
    },
    "./patches": {
      "types": "./dist/patches/index.d.ts",
      "import": "./dist/patches/index.js",
      "require": "./dist/patches/index.js"
    },
    "./workflow": {
      "types": "./dist/workflow/index.d.ts",
      "import": "./dist/workflow/index.js",
      "require": "./dist/workflow/index.js"
    },
    "./services": {
      "types": "./dist/services/index.d.ts",
      "import": "./dist/services/index.js",
      "require": "./dist/services/index.js"
    },
    "./logger": {
      "types": "./dist/logger/index.d.ts",
      "import": "./dist/logger/index.js",
      "require": "./dist/logger/index.js"
    },
    "./validation": {
      "types": "./dist/validation/index.d.ts",
      "import": "./dist/validation/index.js",
      "require": "./dist/validation/index.js"
    },
    "./image": {
      "types": "./dist/image/index.d.ts",
      "import": "./dist/image/index.js",
      "require": "./dist/image/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@byline/auth": "workspace:*",
    "dotenv": "^17.4.2",
    "pino": "^10.3.1",
    "sharp": "^0.35.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.2",
    "@types/node": "^26.1.0",
    "chokidar": "^5.0.0",
    "chokidar-cli": "^3.0.0",
    "npm-run-all": "^4.1.5",
    "tsc-alias": "^1.9.0",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
