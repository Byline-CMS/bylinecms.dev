{
  "name": "@byline/host-tanstack-start",
  "private": false,
  "type": "module",
  "license": "MPL-2.0",
  "version": "0.9.2",
  "engines": {
    "node": ">=20.9.0"
  },
  "description": "TanStack Start host adapter for Byline CMS — server fns, auth context, integration glue, admin shell, and route factories",
  "keywords": [
    "cms",
    "headless cms",
    "content management",
    "tanstack",
    "tanstack start"
  ],
  "homepage": "https://github.com/Byline-CMS/bylinecms.dev",
  "bugs": {
    "url": "https://github.com/Byline-CMS/bylinecms.dev/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Byline-CMS/bylinecms.dev.git",
    "directory": "packages/host-tanstack-start"
  },
  "scripts": {
    "dev": "run-p dev:*",
    "dev:code": "rslib build --watch",
    "build": "run-s build:*",
    "build:clean": "rimraf dist build",
    "build:code": "rslib build",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf node_modules dist build types .turbo",
    "lint": "biome check --write --unsafe --diagnostic-level=error",
    "test": "vitest run --mode=node"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "main": "./dist/index.js",
  "files": [
    "dist/",
    "src/"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "main": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./server-fns/admin-account": {
      "types": "./dist/server-fns/admin-account/index.d.ts",
      "import": "./dist/server-fns/admin-account/index.js"
    },
    "./server-fns/admin-permissions": {
      "types": "./dist/server-fns/admin-permissions/index.d.ts",
      "import": "./dist/server-fns/admin-permissions/index.js"
    },
    "./server-fns/admin-roles": {
      "types": "./dist/server-fns/admin-roles/index.d.ts",
      "import": "./dist/server-fns/admin-roles/index.js"
    },
    "./server-fns/admin-users": {
      "types": "./dist/server-fns/admin-users/index.d.ts",
      "import": "./dist/server-fns/admin-users/index.js"
    },
    "./server-fns/auth": {
      "types": "./dist/server-fns/auth/index.d.ts",
      "import": "./dist/server-fns/auth/index.js"
    },
    "./server-fns/collections": {
      "types": "./dist/server-fns/collections/index.d.ts",
      "import": "./dist/server-fns/collections/index.js"
    },
    "./server-fns/preview": {
      "types": "./dist/server-fns/preview/index.d.ts",
      "import": "./dist/server-fns/preview/index.js"
    },
    "./server-fns/*": {
      "types": "./dist/server-fns/*.d.ts",
      "import": "./dist/server-fns/*.js"
    },
    "./auth/*": {
      "types": "./dist/auth/*.d.ts",
      "import": "./dist/auth/*.js"
    },
    "./integrations/*": {
      "types": "./dist/integrations/*.d.ts",
      "import": "./dist/integrations/*.js"
    },
    "./admin-shell/*": {
      "types": "./dist/admin-shell/*.d.ts",
      "import": "./dist/admin-shell/*.js"
    },
    "./routes": {
      "types": "./dist/routes/index.d.ts",
      "import": "./dist/routes/index.js"
    },
    "./routes/*": {
      "types": "./dist/routes/*.d.ts",
      "import": "./dist/routes/*.js"
    }
  },
  "dependencies": {
    "@byline/admin": "workspace:*",
    "@byline/auth": "workspace:*",
    "@byline/client": "workspace:*",
    "@byline/core": "workspace:*",
    "@byline/ui": "workspace:*",
    "@infonomic/uikit": "^6.7.1",
    "classnames": "^2.5.1",
    "npm-run-all": "^4.1.5",
    "react-json-view-lite": "^2.5.0",
    "react-swipeable": "^7.0.2",
    "uuid": "^14.0.0",
    "zod": "^4.4.2"
  },
  "peerDependencies": {
    "@byline/db-postgres": "workspace:*",
    "@byline/storage-local": "workspace:*",
    "@tanstack/react-router": "^1.167.0",
    "@tanstack/react-start": "^1.167.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "@byline/db-postgres": {
      "optional": false
    },
    "@byline/storage-local": {
      "optional": false
    }
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@byline/db-postgres": "workspace:*",
    "@byline/storage-local": "workspace:*",
    "@rsbuild/plugin-react": "^2.0.0",
    "@rslib/core": "^0.21.3",
    "@tanstack/react-router": "^1.169.1",
    "@tanstack/react-start": "^1.167.61",
    "@types/node": "^25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "lightningcss": "^1.32.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "rimraf": "^6.1.3",
    "typescript": "6.0.3",
    "typescript-plugin-css-modules": "^5.2.0",
    "vitest": "^4.1.5"
  },
  "publishConfig": {
    "access": "public",
    "files": [
      "dist/",
      "src/"
    ]
  }
}
