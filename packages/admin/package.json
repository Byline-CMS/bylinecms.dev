{
  "name": "@byline/admin",
  "private": false,
  "license": "MPL-2.0",
  "version": "0.9.2",
  "description": "Byline CMS admin subsystem — admin users, roles, permissions, account self-service, and the built-in JWT session provider",
  "keywords": [
    "cms",
    "headless cms",
    "content management",
    "authentication",
    "authorization",
    "admin"
  ],
  "homepage": "https://github.com/Byline-CMS/bylinecms.dev",
  "bugs": {
    "url": "https://github.com/Byline-CMS/bylinecms.dev/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Byline-CMS/bylinecms.dev.git",
    "directory": "packages/admin"
  },
  "type": "module",
  "main": "dist/index.js",
  "index": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "chokidar 'src/**/*' -c 'npm-run-all build'",
    "build": "tsc -p tsconfig.json && tsc-alias",
    "clean": "rimraf node_modules dist build .turbo",
    "lint": "biome check --write --unsafe --diagnostic-level=error",
    "test": "vitest run --mode=node",
    "test:watch": "vitest --mode=node",
    "typecheck": "tsc --noEmit"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/modules/auth/index.d.ts",
      "import": "./dist/modules/auth/index.js",
      "require": "./dist/modules/auth/index.js"
    },
    "./admin-users": {
      "types": "./dist/modules/admin-users/index.d.ts",
      "import": "./dist/modules/admin-users/index.js",
      "require": "./dist/modules/admin-users/index.js"
    },
    "./admin-roles": {
      "types": "./dist/modules/admin-roles/index.d.ts",
      "import": "./dist/modules/admin-roles/index.js",
      "require": "./dist/modules/admin-roles/index.js"
    },
    "./admin-permissions": {
      "types": "./dist/modules/admin-permissions/index.d.ts",
      "import": "./dist/modules/admin-permissions/index.js",
      "require": "./dist/modules/admin-permissions/index.js"
    },
    "./admin-account": {
      "types": "./dist/modules/admin-account/index.d.ts",
      "import": "./dist/modules/admin-account/index.js",
      "require": "./dist/modules/admin-account/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@byline/auth": "workspace:*",
    "@byline/core": "workspace:*",
    "@node-rs/argon2": "^2.0.2",
    "jose": "^6.2.2",
    "npm-run-all": "^4.1.5",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@types/node": "^25.6.0",
    "chokidar": "^5.0.0",
    "chokidar-cli": "^3.0.0",
    "rimraf": "^6.0.1",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "6.0.2",
    "vitest": "^4.1.4"
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.js"
      },
      "./auth": {
        "types": "./dist/modules/auth/index.d.ts",
        "import": "./dist/modules/auth/index.js",
        "require": "./dist/modules/auth/index.js"
      },
      "./admin-users": {
        "types": "./dist/modules/admin-users/index.d.ts",
        "import": "./dist/modules/admin-users/index.js",
        "require": "./dist/modules/admin-users/index.js"
      },
      "./admin-roles": {
        "types": "./dist/modules/admin-roles/index.d.ts",
        "import": "./dist/modules/admin-roles/index.js",
        "require": "./dist/modules/admin-roles/index.js"
      },
      "./admin-permissions": {
        "types": "./dist/modules/admin-permissions/index.d.ts",
        "import": "./dist/modules/admin-permissions/index.js",
        "require": "./dist/modules/admin-permissions/index.js"
      },
      "./admin-account": {
        "types": "./dist/modules/admin-account/index.d.ts",
        "import": "./dist/modules/admin-account/index.js",
        "require": "./dist/modules/admin-account/index.js"
      },
      "./package.json": "./package.json"
    },
    "main": "dist/index.js",
    "index": "dist/index.js",
    "types": "dist/index.d.ts",
    "registry": "https://registry.npmjs.org/"
  }
}
