{
  "$schema": "https://turborepo.org/schema.json",
  "ui": "stream",
  "concurrency": "20",
  "tasks": {
    "build": {
      "cache": false,
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "build/**"]
    },
    "dev": {
      "cache": false,
      "outputs": [],
      "env": ["NODE_ENV"],
      "persistent": true
    },
    "db:init": {
      "cache": false,
      "persistent": true,
      "interactive": true
    },
    "byline:generate": {
      "cache": false
    },
    "drizzle:generate": {
      "cache": false
    },
    "drizzle:migrate": {
      "cache": false
    },
    "dev:seed": {
      "cache": false
    },
    "clean": {
      "cache": false
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": [],
      "inputs": ["src/**/*.ts", "src/**/*.tsx", "tsconfig.json"]
    },
    "test": {
      "outputs": []
    },
    "test:integration": {
      "dependsOn": ["^build"],
      "outputs": [],
      "cache": false,
      "env": ["POSTGRES_CONNECTION_STRING"]
    },
    "preview": {
      "cache": false,
      "dependsOn": ["^preview"],
      "persistent": true
    },
    "start": {
      "cache": false,
      "dependsOn": ["^start"],
      "persistent": true
    }
  },
  "globalEnv": []
}
