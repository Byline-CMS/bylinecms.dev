{
  "name": "@byline/webapp",
  "private": true,
  "license": "MPL-2.0",
  "version": "0.9.2",
  "description": "Byline CMS dashboard app",
  "keywords": [
    "cms",
    "headless cms",
    "content management"
  ],
  "homepage": "https://github.com/Byline-CMS/bylinecms.dev",
  "bugs": {
    "url": "https://github.com/Byline-CMS/bylinecms.dev/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Byline-CMS/bylinecms.dev.git",
    "directory": "apps/dashboard"
  },
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview --port 5173",
    "start": "NODE_ENV=production PORT=5173 node --env-file=.env.local .output/server/index.mjs",
    "clean": "node scripts/clean.js node_modules dist build .output .nitro .tanstack .turbo",
    "lint": "biome check --write --unsafe --diagnostic-level=error",
    "test": "vitest run --mode=jsdom && vitest run --mode=node --passWithNoTests",
    "test:jsdom": "vitest run --mode=jsdom",
    "test:node": "vitest run --mode=node",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@byline/admin": "workspace:*",
    "@byline/ai": "workspace:*",
    "@byline/auth": "workspace:*",
    "@byline/client": "workspace:*",
    "@byline/core": "workspace:*",
    "@byline/db-postgres": "workspace:*",
    "@byline/host-tanstack-start": "workspace:*",
    "@byline/i18n": "workspace:*",
    "@byline/richtext-lexical": "workspace:*",
    "@byline/storage-local": "workspace:*",
    "@byline/ui": "workspace:*",
    "@formatjs/intl-localematcher": "^0.8.8",
    "@infonomic/schemas": "^2.4.0",
    "@tanstack/react-form": "^1.32.0",
    "@tanstack/react-form-start": "^1.32.0",
    "@tanstack/react-query": "^5.100.13",
    "@tanstack/react-router": "^1.170.7",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/react-start": "^1.168.10",
    "dotenv": "^17.4.2",
    "gray-matter": "^4.0.3",
    "intl-messageformat": "^11.2.7",
    "mdast-util-to-string": "^4.0.0",
    "negotiator": "^1.0.0",
    "nitro": "npm:nitro-nightly@3.0.260522-beta",
    "pino": "^10.3.1",
    "prism-react-renderer": "^2.4.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-swipeable": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "sharp": "^0.34.5",
    "unified": "^11.0.5",
    "uuid": "^14.0.0",
    "zod": "^4.4.3",
    "zod-form-data": "^3.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@tailwindcss/vite": "4.3.0",
    "@tanstack/devtools-vite": "^0.7.0",
    "@tanstack/react-form-devtools": "^0.2.27",
    "@types/mdast": "^4.0.4",
    "@types/negotiator": "^0.6.4",
    "@types/node": "^25.9.1",
    "@types/nodemailer": "^8.0.0",
    "@types/nodemailer-html-to-text": "^3.1.3",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "add": "^2.0.6",
    "classnames": "^2.5.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "4.3.0",
    "tsx": "^4.22.3",
    "typescript": "6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
