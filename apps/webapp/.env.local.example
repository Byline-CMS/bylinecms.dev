# Template for `.env.local` — copy this file to `.env.local` and fill in the
# values for your machine. `.env.local` is gitignored and is where secrets
# and machine-specific overrides live.
#
# This webapp follows the TanStack Start / Vite convention for environment
# files:
#
#   .env             Committed. Public, build-time `VITE_*` defaults for
#                    local development (site name, dev server URL, feature
#                    toggles). Safe to inline into the client bundle.
#
#   .env.local       Gitignored. Secrets and machine-specific overrides
#                    (DB connection string, JWT signing secret, AI keys,
#                    S3 credentials). Server-only — never inlined into the
#                    client bundle.
#
#   .env.production  Committed. Production overrides of the public `VITE_*`
#                    keys. Read by Vite when building with `--mode production`
#                    (the default for `vite build`).
#                    Should NOT contain secrets!!!!!
#
# See the TanStack Start docs for the full env file load order and merge
# precedence:
#
#   https://tanstack.com/start/latest/docs/framework/react/guide/environment-variables#environment-file-setup
#
# DO NOT change the name of the database used locally for development —
# byline_dev — if you would like to use the `db_init.sh` script located in
# `packages/db-postgres/src/database/db_init.sh`. The script is an
# anti-foot-cannon measure: it refuses to operate on a database whose name
# does not end in `_dev` or `_test`.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Single source of truth — the db_init scripts in packages/db-postgres parse
# this URL to derive user / password / host / port / database. Must use the
# postgres:// or postgresql:// scheme.
BYLINE_DB_POSTGRES_CONNECTION_STRING=postgres://byline:byline@127.0.0.1:5432/byline_dev

# Optional pg connection pool tuning. Leave unset to use the adapter
# defaults (max: 20, idleTimeoutMillis: 2000, connectionTimeoutMillis:
# 30000). Worth tuning for serverless Postgres providers like Neon,
# where the database sleeps and cold starts can stretch past the
# default 2-second connect timeout. A 30-second connect timeout is a
# safe starting point for Neon-style cold starts.
# BYLINE_DB_POSTGRES_MAX_POOL=20
# BYLINE_DB_POSTGRES_IDLE_TIMEOUT_MILLIS=2000
# BYLINE_DB_POSTGRES_CONNECTION_TIMEOUT_MILLIS=30000

# ---------------------------------------------------------------------------
# Admin auth
# ---------------------------------------------------------------------------
# Signing secret for the built-in JwtSessionProvider. Must be at least
# 32 bytes of entropy. Generate one with:
#   openssl rand -base64 48
# In production, load this from a secret manager — never commit it.
BYLINE_JWT_SECRET=dev-secret-replace-me-with-openssl-rand-base64-48-output

# Super-admin seed credentials. Used by the byline/seed.ts orchestrator to
# bootstrap the initial admin account. Change for any non-dev deployment.
BYLINE_SUPERADMIN_EMAIL=admin@byline.local
BYLINE_SUPERADMIN_PASSWORD=change-me

# ---------------------------------------------------------------------------
# Storage — S3 (optional, for @byline/storage-s3)
# ---------------------------------------------------------------------------
# Only required when byline/server.config.ts is wired to s3StorageProvider().
# Leave commented out when using the default localStorageProvider().
#
# Works with AWS S3, Cloudflare R2, MinIO, and any S3-API-compatible store.
# When deploying to AWS with an IAM role / instance profile, leave the key
# pair below unset and the AWS SDK will resolve credentials via its default
# provider chain — never bake long-lived keys into a deployed image.

# Required.
# BYLINE_STORAGE_S3_BUCKET=my-cms-bucket
# BYLINE_STORAGE_S3_REGION=eu-west-1

# Optional — explicit long-lived credentials. Omit on AWS to use the default
# credential chain (IAM role / SSO / env / ~/.aws/credentials). Required for
# Cloudflare R2 and MinIO.
# BYLINE_STORAGE_S3_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
# BYLINE_STORAGE_S3_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional — public read URL. When omitted, the provider derives a default
# AWS URL: https://<bucket>.s3.<region>.amazonaws.com. Set this for CDN
# fronting (CloudFront, Cloudflare) or non-AWS providers.
# BYLINE_STORAGE_S3_PUBLIC_URL=https://cdn.example.com

# Optional — custom endpoint + path-style addressing for S3-compatible
# providers (Cloudflare R2, MinIO, etc.). Leave unset for AWS S3.
# BYLINE_STORAGE_S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# BYLINE_STORAGE_S3_FORCE_PATH_STYLE=true

# Optional — namespacing inside the bucket. No leading slash; trailing slash
# added automatically. Useful when sharing a bucket with other apps.
# BYLINE_STORAGE_S3_PATH_PREFIX=byline

# ---------------------------------------------------------------------------
# AI (optional, for @byline/ai)
# ---------------------------------------------------------------------------
# Only required when @byline/ai is installed and a richtext field is wired to
# the AI extension (see the LexicalRichTextAi pattern in byline/admin.config).
# Leave commented out for installations that do not use the AI assistant.
#
# `AI_DEFAULT_PROVIDER` picks which provider's keys are read at startup —
# only the matching block below needs to be uncommented. `*_BASE_URL` entries
# are optional and only needed when routing through a proxy or a non-default
# endpoint (e.g. Azure OpenAI, a self-hosted gateway).

# AI_DEFAULT_PROVIDER=openai

# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# GOOGLE_API_KEY=...
# GOOGLE_BASE_URL=https://generativelanguage.googleapis.com

# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# Optional — override the in-process AI endpoint mounted by the host adapter.
# Defaults to the value baked into @byline/ai; only set this if you have
# remapped the route.
# BYLINE_AI_ENDPOINT=/api/admin/ai

# Optional L1 in-memory data cache (see docs/DATA-CACHE-DESIGN.md). All OFF
# by default — adopters opt in deliberately. Used by the sitemap getters
# (src/modules/*/sitemap.ts) and any read wrapped in withCache().
# CACHING_DATA_REQUESTS=true
# CACHING_TTL=60000
# CACHING_REFRESH_THRESHOLD=15000

# Cross-instance invalidation fan-out for multi-machine deployments (Fly.io
# 6PN). Leave OFF for a single origin behind a CDN.
# CACHING_CLUSTER_ENABLED=false
# PRIVATE_NETWORK_DOMAIN=
# PRIVATE_NETWORK_APPLICATION_PORT=
