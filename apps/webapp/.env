# Public, build-time defaults for the webapp. Following the TanStack Start /
# Vite convention this file IS committed to source control — only `VITE_*`
# keys belong here, and only values that are safe to inline into the client
# bundle (site name, public URLs, feature toggles). Secrets and machine-
# specific overrides go in `.env.local` (gitignored). Production overrides
# of these same keys go in `.env.production` (also committed).
#
# See: https://tanstack.com/start/latest/docs/framework/react/guide/environment-variables#environment-file-setup

VITE_SITE_NAME=Byline CMS
VITE_SITE_DESCRIPTION='An open-source, AI-ready headless CMS.'
VITE_SERVER_URL=http://localhost:5173
