# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
.vscode

# dependencies
node_modules
.pnp
.pnp.js

# testing
coverage

.next/
out/
build
dist
.output
.nitro

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm-debug.log*

# local env files
.env
.env.local
.env.test
.env.development.local
.env.test.local
.env.production.local

# turbo
.turbo

# TypeScript incremental build cache
*.tsbuildinfo

# .env
.env

# https://tanstack.com/start/latest/docs/framework/react/guide/environment-variables#environment-file-setup
# apps/webapp follows the TanStack Start / Vite convention where `.env` and
# `.env.production` hold public, build-time defaults that ARE committed,
# while `.env.local` (still ignored above) holds secrets. Whitelist the
# committed files here so the broader `.env` rule does not catch them.
# Other workspaces (packages/db-postgres, packages/client, ...) keep the
# default behaviour — their `.env` files remain ignored.
!apps/webapp/.env
!apps/webapp/.env.production


# Ignore our local postgres data directory
postgres/data
postgres/backups

# Ignore our local mysql data directory
mysql/data
mysql/backups

# pnpm's project-local store fallback (created when the global store
# isn't writable, e.g. sandboxed agent shells) — machine-local cache
.pnpm-store/

# Claude Code local/personal config
.claude/settings.local.json
.claude/.mcp.local.json
.claude/scheduled_tasks.lock

.superpowers
