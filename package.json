{
  "name": "@byline/root",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "clean": "turbo run clean && rimraf node_modules",
    "db:init": "TURBO_UI=true turbo run db:init",
    "byline:generate": "turbo run byline:generate",
    "drizzle:generate": "turbo run drizzle:generate",
    "drizzle:migrate": "turbo run drizzle:migrate",
    "build": "turbo run build",
    "build:packages": "turbo run build --filter=\"./packages/*\"",
    "preview": "turbo run preview",
    "storybook": "turbo run storybook",
    "dev": "turbo run dev",
    "lint": "turbo run lint --continue",
    "typecheck": "turbo run typecheck --continue",
    "test": "turbo run test",
    "version-packages": "changeset version",
    "release:tag": "turbo run build --filter=\"./packages/*\" && changeset tag",
    "release:npm": "turbo run build --filter=\"./packages/*\" && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@changesets/cli": "^2.31.0"
  },
  "dependencies": {
    "turbo": "^2.9.8",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "pnpm": {
    "allowedDeprecatedVersions": {
      "abab": "2",
      "domexception": "4"
    },
    "overrides": {
      "typescript": "$typescript",
      "react": "19.2.5",
      "react-dom": "19.2.5"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@tailwindcss/oxide",
      "argon2",
      "core-js",
      "esbuild",
      "lightningcss-cli",
      "sharp"
    ]
  }
}
